              <option name="filePath" value="$PROJECT_DIR$/registration/index.html" />
              <option name="originalContent" value="&lt;!DOCTYPE html&gt;&#10;&lt;html lang='en'&gt;&#10;&#10;&lt;head&gt;&#10;    &lt;base href=&quot;..&quot;&gt;&#10;    &lt;link rel=&quot;shortcut icon&quot; type=&quot;image/png&quot; href=&quot;assets/favicon.png&quot;/&gt;&#10;    &lt;link rel=&quot;stylesheet&quot; type=&quot;text/css&quot; media=&quot;all&quot; href=&quot;assets/main.css&quot;/&gt;&#10;    &lt;meta name=&quot;description&quot; content=&quot;Abstract Submission for the 2nd Greater Bay Area Physical Science Young Scientist Forum&quot;&gt;&#10;    &lt;meta name=&quot;resource-type&quot; content=&quot;document&quot;&gt;&#10;    &lt;meta name=&quot;distribution&quot; content=&quot;global&quot;&gt;&#10;    &lt;meta name=&quot;KeyWords&quot; content=&quot;Forum 2026, Abstract Submission, Greater Bay Area, Physical Science&quot;&gt;&#10;    &lt;title&gt;Abstract Submission | Forum 2026&lt;/title&gt;&#10;&lt;/head&gt;&#10;&#10;&lt;body&gt;&#10;&#10;    &lt;div class=&quot;banner&quot;&gt;&#10;        &lt;img src=&quot;assets/banner.png&quot; alt=&quot;Forum 2026 Banner&quot;&gt;&#10;    &lt;/div&gt;&#10;&#10;    &lt;table class=&quot;navigation&quot;&gt;&#10;        &lt;tr&gt;&#10;            &lt;td class=&quot;navigation&quot;&gt;&#10;                &lt;a title=&quot;Conference Home Page&quot; href=&quot;.&quot;&gt;Home&lt;/a&gt;&#10;            &lt;/td&gt;&#10;            &lt;td class=&quot;navigation&quot;&gt;&#10;                &lt;a class=&quot;current&quot; title=&quot;Abstract Submission&quot; href=&quot;registration&quot;&gt;Abstract Submission&lt;/a&gt;&#10;            &lt;/td&gt;&#10;            &lt;td class=&quot;navigation&quot;&gt;&#10;                &lt;a title=&quot;Presentation Schedule&quot; href=&quot;program&quot;&gt;Presentation Schedule&lt;/a&gt;&#10;            &lt;/td&gt;&#10;            &lt;td class=&quot;navigation&quot;&gt;&#10;                &lt;a title=&quot;Conference Venue and Transportation&quot; href=&quot;directions&quot;&gt;Conference Venue and Transportation&lt;/a&gt;&#10;            &lt;/td&gt;&#10;        &lt;/tr&gt;&#10;    &lt;/table&gt;&#10;&#10;    &lt;h2&gt;Abstract Submission&lt;/h2&gt;&#10;&#10;    &lt;p&gt;&#10;        Due to limited venue space, this conference is by invitation only. If you received our invitation and can attend the Forum 2026, please kindly confirm your participation by &lt;strong&gt;submitting your Abstract and indicating your detailed attendance&lt;/strong&gt; via either of the codes below by &lt;strong&gt;April 8, 2026&lt;/strong&gt;.&#10;    &lt;/p&gt;&#10;    &lt;p&gt;&#10;        Please contact Dr. Gang Wang (forum2026cuhk@gmail.com) if you have any questions.&#10;    &lt;/p&gt;&#10;    &lt;p&gt;&#10;        &lt;u&gt;(Scan/click either one to submit abstract and attendance details.)&lt;/u&gt;&#10;    &lt;/p&gt;&#10;    &lt;table class=&quot;registration-qr&quot;&gt;&#10;        &lt;tr&gt;&#10;            &lt;td class=&quot;qr&quot;&gt;&#10;                &lt;div class=&quot;qr-label&quot;&gt;&lt;strong&gt;Google Form&lt;/strong&gt;&lt;/div&gt;&#10;                &lt;img class=&quot;qr-code&quot; src=&quot;assets/google_form.png&quot; alt=&quot;Google Form registration QR code&quot;&gt;&#10;                &lt;div class=&quot;qr-link&quot;&gt;&lt;a href=&quot;https://forms.gle/NxS2m3Q19KSzrfqT8&quot;&gt;https://forms.gle/NxS2m3Q19KSzrfqT8&lt;/a&gt;&lt;/div&gt;&#10;            &lt;/td&gt;&#10;            &lt;td class=&quot;qr&quot;&gt;&#10;                &lt;div class=&quot;qr-label&quot;&gt;&lt;strong&gt;Tencent Form&lt;/strong&gt;&lt;/div&gt;&#10;                &lt;img class=&quot;qr-code&quot; src=&quot;assets/tencent_form.png&quot; alt=&quot;Tencent Form registration QR code&quot;&gt;&#10;                &lt;div class=&quot;qr-link&quot;&gt;&lt;a href=&quot;https://docs.qq.com/form/page/DWWFZeWJTZW9iZ1RY&quot;&gt;https://docs.qq.com/form/page/DWWFZeWJTZW9iZ1RY&lt;/a&gt;&lt;/div&gt;&#10;            &lt;/td&gt;&#10;        &lt;/tr&gt;&#10;    &lt;/table&gt;&#10;    &lt;p&gt;&#10;        &lt;u&gt;&lt;strong&gt;No registration fee is required.&lt;/strong&gt; Meals will be provided during the Forum.&lt;/u&gt;&#10;    &lt;/p&gt;&#10;    &lt;!--&#10;    &lt;iframe class=&quot;registration&quot; src=&quot;EMBED LINK FOR GOOGLE FORM HERE&quot;&gt;&lt;/iframe&gt;&#10;    --&gt;&#10;&#10;&#10;    &lt;footer&gt;&#10;        &amp;copy; Forum 2026 Organizing Committee&#10;        &amp;nbsp;|&amp;nbsp; Design by &lt;a href=&quot;https://github.com/mikepierce&quot;&gt;Mike Pierce&lt;/a&gt;&#10;    &lt;/footer&gt;&#10;&#10;&lt;/body&gt;&#10;&lt;/html&gt;&#10;&#10;" />
              <option name="updatedContent" value="&lt;!DOCTYPE html&gt;&#10;&lt;html lang='en'&gt;&#10;&#10;&lt;head&gt;&#10;    &lt;base href=&quot;..&quot;&gt;&#10;    &lt;link rel=&quot;shortcut icon&quot; type=&quot;image/png&quot; href=&quot;assets/favicon.png&quot;/&gt;&#10;    &lt;link rel=&quot;stylesheet&quot; type=&quot;text/css&quot; media=&quot;all&quot; href=&quot;assets/main.css&quot;/&gt;&#10;    &lt;meta name=&quot;description&quot; content=&quot;Abstract Submission for the 2nd Greater Bay Area Physical Science Young Scientist Forum&quot;&gt;&#10;    &lt;meta name=&quot;resource-type&quot; content=&quot;document&quot;&gt;&#10;    &lt;meta name=&quot;distribution&quot; content=&quot;global&quot;&gt;&#10;    &lt;meta name=&quot;KeyWords&quot; content=&quot;Forum 2026, Abstract Submission, Greater Bay Area, Physical Science&quot;&gt;&#10;    &lt;title&gt;Abstract Submission | Forum 2026&lt;/title&gt;&#10;&lt;/head&gt;&#10;&#10;&lt;body&gt;&#10;&#10;    &lt;div class=&quot;banner&quot;&gt;&#10;        &lt;img src=&quot;assets/banner.png&quot; alt=&quot;Forum 2026 Banner&quot;&gt;&#10;    &lt;/div&gt;&#10;&#10;    &lt;table class=&quot;navigation&quot;&gt;&#10;        &lt;tr&gt;&#10;            &lt;td class=&quot;navigation&quot;&gt;&#10;                &lt;a title=&quot;Conference Home Page&quot; href=&quot;.&quot;&gt;Home&lt;/a&gt;&#10;            &lt;/td&gt;&#10;            &lt;td class=&quot;navigation&quot;&gt;&#10;                &lt;a class=&quot;current&quot; title=&quot;Abstract Submission&quot; href=&quot;registration&quot;&gt;Abstract Submission&lt;/a&gt;&#10;            &lt;/td&gt;&#10;            &lt;td class=&quot;navigation&quot;&gt;&#10;                &lt;a title=&quot;Presentation Schedule&quot; href=&quot;program&quot;&gt;Presentation Schedule&lt;/a&gt;&#10;            &lt;/td&gt;&#10;            &lt;td class=&quot;navigation&quot;&gt;&#10;                &lt;a title=&quot;Conference Venue and Transportation&quot; href=&quot;directions&quot;&gt;Conference Venue and Transportation&lt;/a&gt;&#10;            &lt;/td&gt;&#10;        &lt;/tr&gt;&#10;    &lt;/table&gt;&#10;&#10;    &lt;h2&gt;Abstract Submission&lt;/h2&gt;&#10;&#10;    &lt;p&gt;&#10;        Due to limited venue space, this conference is by invitation only. If you received our invitation and can attend the Forum 2026, please kindly confirm your participation by &lt;strong&gt;submitting your Abstract and indicating your detailed attendance&lt;/strong&gt; via either of the codes below by &lt;strong&gt;April 8, 2026&lt;/strong&gt;.&#10;    &lt;/p&gt;&#10;    &lt;p&gt;&#10;        Please contact Dr. Gang Wang (forum2026cuhk@gmail.com) if you have any questions.&#10;    &lt;/p&gt;&#10;    &lt;p&gt;&#10;        &lt;u&gt;(Scan/click either one to submit abstract and attendance details.)&lt;/u&gt;&#10;    &lt;/p&gt;&#10;    &lt;table class=&quot;registration-qr&quot;&gt;&#10;        &lt;tr&gt;&#10;            &lt;td class=&quot;qr&quot;&gt;&#10;                &lt;div class=&quot;qr-label&quot;&gt;&lt;strong&gt;Google Form&lt;/strong&gt;&lt;/div&gt;&#10;                &lt;img class=&quot;qr-code&quot; src=&quot;assets/google_form.png&quot; alt=&quot;Google Form registration QR code&quot;&gt;&#10;                &lt;div class=&quot;qr-link&quot;&gt;&lt;a href=&quot;https://forms.gle/NxS2m3Q19KSzrfqT8&quot;&gt;https://forms.gle/NxS2m3Q19KSzrfqT8&lt;/a&gt;&lt;/div&gt;&#10;            &lt;/td&gt;&#10;            &lt;td class=&quot;qr&quot;&gt;&#10;                &lt;div class=&quot;qr-label&quot;&gt;&lt;strong&gt;Tencent Form&lt;/strong&gt;&lt;/div&gt;&#10;                &lt;img class=&quot;qr-code&quot; src=&quot;assets/tencent_form.png&quot; alt=&quot;Tencent Form registration QR code&quot;&gt;&#10;                &lt;div class=&quot;qr-link&quot;&gt;&lt;a href=&quot;https://docs.qq.com/form/page/DWWFZeWJTZW9iZ1RY&quot;&gt;https://docs.qq.com/form/page/DWWFZeWJTZW9iZ1RY&lt;/a&gt;&lt;/div&gt;&#10;            &lt;/td&gt;&#10;        &lt;/tr&gt;&#10;    &lt;/table&gt;&#10;    &lt;p&gt;&#10;        &lt;u&gt;&lt;strong&gt;No registration fee is required.&lt;/strong&gt; Meals will be provided during the Forum.&lt;/u&gt;&#10;    &lt;/p&gt;&#10;    &lt;!--&#10;    &lt;iframe class=&quot;registration&quot; src=&quot;EMBED LINK FOR GOOGLE FORM HERE&quot;&gt;&lt;/iframe&gt;&#10;    --&gt;&#10;&#10;&#10;    &lt;footer&gt;&#10;        &amp;copy; Forum 2026 Organizing Committee&#10;        &amp;nbsp;|&amp;nbsp; Designed by &lt;a href=&quot;https://github.com/liu-jing-yi&quot;&gt;Jingyi Liu&lt;/a&gt;, using template from &lt;a href=&quot;https://github.com/mikepierce&quot;&gt;Mike Pierce&lt;/a&gt;&#10;    &lt;/footer&gt;&#10;&#10;&lt;/body&gt;&#10;&lt;/html&gt;&#10;&#10;" />
