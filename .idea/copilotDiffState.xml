              <option name="originalContent" value="&lt;!DOCTYPE html&gt;&#10;&lt;html lang='en'&gt;&#10;&#10;&lt;head&gt;&#10;    &lt;base href=&quot;..&quot;&gt;&#10;    &lt;link rel=&quot;shortcut icon&quot; type=&quot;image/png&quot; href=&quot;assets/favicon.png&quot;/&gt;&#10;    &lt;link rel=&quot;stylesheet&quot; type=&quot;text/css&quot; media=&quot;all&quot; href=&quot;assets/main.css&quot;/&gt;&#10;    &lt;meta name=&quot;description&quot; content=&quot;Directions to the 2nd Greater Bay Area Physical Science Young Scientist Forum at CUHK&quot;&gt;&#10;    &lt;meta name=&quot;resource-type&quot; content=&quot;document&quot;&gt;&#10;    &lt;meta name=&quot;distribution&quot; content=&quot;global&quot;&gt;&#10;    &lt;meta name=&quot;KeyWords&quot; content=&quot;Forum 2026, Directions, CUHK, Hong Kong&quot;&gt;&#10;    &lt;title&gt;Directions | Forum 2026&lt;/title&gt;&#10;&lt;/head&gt;&#10;&#10;&lt;body&gt;&#10;&#10;    &lt;div class=&quot;banner&quot;&gt;&#10;        &lt;img src=&quot;assets/banner.png&quot; alt=&quot;Forum 2026 Banner&quot;&gt;&#10;    &lt;/div&gt;&#10;&#10;    &lt;table class=&quot;navigation&quot;&gt;&#10;        &lt;tr&gt;&#10;            &lt;td class=&quot;navigation&quot;&gt;&#10;                &lt;a title=&quot;Conference Home Page&quot; href=&quot;.&quot;&gt;Home&lt;/a&gt;&#10;            &lt;/td&gt;&#10;            &lt;td class=&quot;navigation&quot;&gt;&#10;                &lt;a title=&quot;Register for the Conference&quot; href=&quot;registration&quot;&gt;Registration&lt;/a&gt;&#10;            &lt;/td&gt;&#10;            &lt;td class=&quot;navigation&quot;&gt;&#10;                &lt;a title=&quot;Conference Program&quot; href=&quot;program&quot;&gt;Program&lt;/a&gt; &#10;            &lt;/td&gt;&#10;            &lt;td class=&quot;navigation&quot;&gt;&#10;                &lt;a class=&quot;current&quot; title=&quot;Directions to the Conference&quot; href=&quot;directions&quot;&gt;Directions&lt;/a&gt;&#10;            &lt;/td&gt;&#10;        &lt;/tr&gt;&#10;    &lt;/table&gt;&#10;&#10;&#10;    &lt;h2&gt;Venue&lt;/h2&gt;&#10;    &lt;p&gt;&#10;        Forum 2026 will be held at &lt;strong&gt;The Chinese University of Hong Kong (CUHK)&lt;/strong&gt;, Hong Kong, China.&#10;    &lt;/p&gt;&#10;&#10;    &lt;iframe class=&quot;directions&quot; src=&quot;https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3688.5018692498997!2d114.20598231544386!3d22.41967598528788!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3404089c3a702e29%3A0x2a7f8b140149c0e3!2sThe%20Chinese%20University%20of%20Hong%20Kong!5e0!3m2!1sen!2shk!4v1710000000000!5m2!1sen!2shk&quot;&gt;&lt;/iframe&gt;&#10;&#10;    &lt;h2&gt;Getting to CUHK&lt;/h2&gt;&#10;    &lt;p&gt;&#10;        &lt;strong&gt;By MTR (Mass Transit Railway):&lt;/strong&gt; Take the East Rail Line to University Station. CUHK campus is directly accessible from the station.&#10;    &lt;/p&gt;&#10;    &lt;p&gt;&#10;        &lt;strong&gt;By Taxi:&lt;/strong&gt; Taxis are widely available throughout Hong Kong. Ask the driver for &amp;ldquo;The Chinese University of Hong Kong, Sha Tin.&amp;rdquo;&#10;    &lt;/p&gt;&#10;    &lt;p&gt;&#10;        &lt;strong&gt;From Hong Kong International Airport:&lt;/strong&gt; Take the Airport Express to Kowloon or Hong Kong Station, then transfer to the East Rail Line heading towards Lo Wu/Lok Ma Chau and alight at University Station.&#10;    &lt;/p&gt;&#10;&#10;    &lt;h2&gt;Contact&lt;/h2&gt;&#10;    &lt;p&gt;&#10;        If you have any questions, please contact Prof. Dr. Ye Chen or Dr. Gang Wang at&#10;        &lt;a href=&quot;mailto:forum2026cuhk@gmail.com&quot;&gt;forum2026cuhk@gmail.com&lt;/a&gt;.&#10;    &lt;/p&gt;&#10;&#10;    &lt;footer&gt;&#10;        &amp;copy; Forum 2026 Organizing Committee&#10;        &amp;nbsp;|&amp;nbsp; Design by &lt;a href=&quot;https://github.com/mikepierce&quot;&gt;Mike Pierce&lt;/a&gt;&#10;    &lt;/footer&gt;&#10;&#10;&lt;/body&gt;&#10;&lt;/html&gt;&#10;" />
              <option name="updatedContent" value="&lt;!DOCTYPE html&gt;&#10;&lt;html lang='en'&gt;&#10;&#10;&lt;head&gt;&#10;    &lt;base href=&quot;..&quot;&gt;&#10;    &lt;link rel=&quot;shortcut icon&quot; type=&quot;image/png&quot; href=&quot;assets/favicon.png&quot;/&gt;&#10;    &lt;link rel=&quot;stylesheet&quot; type=&quot;text/css&quot; media=&quot;all&quot; href=&quot;assets/main.css&quot;/&gt;&#10;    &lt;meta name=&quot;description&quot; content=&quot;Conference Venue and Transportation for the 2nd Greater Bay Area Physical Science Young Scientist Forum at CUHK&quot;&gt;&#10;    &lt;meta name=&quot;resource-type&quot; content=&quot;document&quot;&gt;&#10;    &lt;meta name=&quot;distribution&quot; content=&quot;global&quot;&gt;&#10;    &lt;meta name=&quot;KeyWords&quot; content=&quot;Forum 2026, Conference Venue and Transportation, CUHK, Hong Kong&quot;&gt;&#10;    &lt;title&gt;Conference Venue and Transportation | Forum 2026&lt;/title&gt;&#10;&lt;/head&gt;&#10;&#10;&lt;body&gt;&#10;&#10;    &lt;div class=&quot;banner&quot;&gt;&#10;        &lt;img src=&quot;assets/banner.png&quot; alt=&quot;Forum 2026 Banner&quot;&gt;&#10;    &lt;/div&gt;&#10;&#10;    &lt;table class=&quot;navigation&quot;&gt;&#10;        &lt;tr&gt;&#10;            &lt;td class=&quot;navigation&quot;&gt;&#10;                &lt;a title=&quot;Conference Home Page&quot; href=&quot;.&quot;&gt;Home&lt;/a&gt;&#10;            &lt;/td&gt;&#10;            &lt;td class=&quot;navigation&quot;&gt;&#10;                &lt;a title=&quot;Abstract Submission&quot; href=&quot;registration&quot;&gt;Abstract Submission&lt;/a&gt;&#10;            &lt;/td&gt;&#10;            &lt;td class=&quot;navigation&quot;&gt;&#10;                &lt;a title=&quot;Presentation Schedule&quot; href=&quot;program&quot;&gt;Presentation Schedule&lt;/a&gt; &#10;            &lt;/td&gt;&#10;            &lt;td class=&quot;navigation&quot;&gt;&#10;                &lt;a class=&quot;current&quot; title=&quot;Conference Venue and Transportation&quot; href=&quot;directions&quot;&gt;Conference Venue and Transportation&lt;/a&gt;&#10;            &lt;/td&gt;&#10;        &lt;/tr&gt;&#10;    &lt;/table&gt;&#10;&#10;&#10;    &lt;h2&gt;Conference Venue and Transportation&lt;/h2&gt;&#10;    &lt;p&gt;&#10;        Forum 2026 will be held at &lt;strong&gt;The Chinese University of Hong Kong (CUHK)&lt;/strong&gt;, Hong Kong, China.&#10;    &lt;/p&gt;&#10;&#10;    &lt;iframe class=&quot;directions&quot; src=&quot;https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3688.5018692498997!2d114.20598231544386!3d22.41967598528788!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3404089c3a702e29%3A0x2a7f8b140149c0e3!2sThe%20Chinese%20University%20of%20Hong%20Kong!5e0!3m2!1sen!2shk!4v1710000000000!5m2!1sen!2shk&quot;&gt;&lt;/iframe&gt;&#10;&#10;    &lt;h2&gt;Getting to CUHK&lt;/h2&gt;&#10;    &lt;p&gt;&#10;        &lt;strong&gt;By MTR (Mass Transit Railway):&lt;/strong&gt; Take the East Rail Line to University Station. CUHK campus is directly accessible from the station.&#10;    &lt;/p&gt;&#10;    &lt;p&gt;&#10;        &lt;strong&gt;By Taxi:&lt;/strong&gt; Taxis are widely available throughout Hong Kong. Ask the driver for &amp;ldquo;The Chinese University of Hong Kong, Sha Tin.&amp;rdquo;&#10;    &lt;/p&gt;&#10;    &lt;p&gt;&#10;        &lt;strong&gt;From Hong Kong International Airport:&lt;/strong&gt; Take the Airport Express to Kowloon or Hong Kong Station, then transfer to the East Rail Line heading towards Lo Wu/Lok Ma Chau and alight at University Station.&#10;    &lt;/p&gt;&#10;&#10;    &lt;h2&gt;Contact&lt;/h2&gt;&#10;    &lt;p&gt;&#10;        If you have any questions, please contact Prof. Dr. Ye Chen or Dr. Gang Wang at&#10;        &lt;a href=&quot;mailto:forum2026cuhk@gmail.com&quot;&gt;forum2026cuhk@gmail.com&lt;/a&gt;.&#10;    &lt;/p&gt;&#10;&#10;    &lt;footer&gt;&#10;        &amp;copy; Forum 2026 Organizing Committee&#10;        &amp;nbsp;|&amp;nbsp; Design by &lt;a href=&quot;https://github.com/mikepierce&quot;&gt;Mike Pierce&lt;/a&gt;&#10;    &lt;/footer&gt;&#10;&#10;&lt;/body&gt;&#10;&lt;/html&gt;&#10;" />
